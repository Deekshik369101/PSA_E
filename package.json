{
  "name": "psa-time-entry",
  "version": "1.0.0",
  "description": "PSA Time Entry System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:push": "npx prisma db push",
    "db:seed": "node seed.js",
    "db:reset": "node -e \"require('fs').rmSync('./prisma/dev.db',{force:true});require('fs').rmSync('./prisma/dev.db-journal',{force:true});\" && npx prisma db push && node seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}